# Copy to .env, fill in your values, then: source .env && python app.py

# ── Provider selection ────────────────────────────────────────────────────────
# Options: anthropic (default), azure, openai
LLM_PROVIDER=anthropic

# ── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-5
# Other options: claude-sonnet-4-5, claude-haiku-4-5-20251001

# ── Azure OpenAI (LLM_PROVIDER=azure) ────────────────────────────────────────
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o        # your deployment name
# AZURE_OPENAI_API_VERSION=2024-02-01   # optional, this is the default

# ── OpenAI direct (LLM_PROVIDER=openai) ──────────────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ── Admin access ────────────────────────────────────────────────────────────
# Secret code that grants admin role on registration (optional)
# Leave blank to disable code-based admin registration
ADMIN_CODE=your-secret-admin-code

# Code that grants superadmin role (cross-institution)
SUPERADMIN_CODE=your-superadmin-code

# ── Scoring tuning ───────────────────────────────────────────────────────────
# Detection threshold — |αQ| ≥ θ or αS ≥ θ triggers a flag
# Lower = more sensitive. 1.5 recommended for small windows (< 5 submissions)
AUTHENTICAI_THETA=1.5

# σ floor as fraction of |μ| — prevents z-score collapse on identical baselines
# Lower = more sensitive to real deviations. 0.02 recommended.
AUTHENTICAI_SIGMA_REL=0.02

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_SECRET=change-me-in-production
